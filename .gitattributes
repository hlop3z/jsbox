# Normalize all text files to LF in the repo; Git auto-detects binary files.
* text=auto eol=lf

# Belt-and-suspenders for the languages/assets in this repo.
*.rs   text eol=lf
*.js   text eol=lf
*.ts   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.toml text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf
*.py   text eol=lf

# Shell scripts must stay LF even on checkout.
Taskfile.yml text eol=lf
Dockerfile   text eol=lf
