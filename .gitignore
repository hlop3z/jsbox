/target
# CARGO_HOME used by the Docker verification build (musl/aws-lc-sys can't build on Windows)
/.cargo-docker
.claude/scheduled_tasks.lock

# ZITADEL service-account PAT (auth integration tests)
.zitadel/

# Working dir the integration harness starts the server from (generated config.json)
.test-run/
# Working dir the A/B stress harness starts servers from
.stress-run/
